# -------------------------------------------------------
# Copy this file to .env and fill in the values.
# -------------------------------------------------------

# ── Docker Hub image names ───────────────────────────
# Used by both `docker compose build/push` (local) and
# `docker compose pull/up` (server, no source code needed).
# Format: <dockerhub-username>/<repo>:<tag>
DOCKER_IMAGE_BACKEND=yourname/flow-backend:latest
DOCKER_IMAGE_FRONTEND=yourname/flow-frontend:latest

# ── Runtime ─────────────────────────────────────────
# Host port the frontend (Nginx) is exposed on (default: 80)
HOST_PORT=80

# Comma-separated origins allowed to open a WebSocket connection.
# Leave empty to allow all origins (fine for local dev, NOT for production).
# Example: https://yourdomain.com
ALLOWED_ORIGINS=

# ── Build-time (frontend only) ───────────────────────
# WebSocket URL baked into the JS bundle at build time.
# Leave empty to auto-derive from window.location.host at runtime
# (works automatically when Nginx proxies /ws on the same origin).
# Override only when the WS endpoint is on a different host/port.
# Example: wss://yourdomain.com/ws
VITE_WS_URL=
